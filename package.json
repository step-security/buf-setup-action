{
  "name": "buf-setup",
  "version": "1.50.0",
  "author": "step-security",
  "scripts": {
    "build": "esbuild --minify --bundle --sourcemap '--define:process.env.NODE_ENV=\"production\"' --outdir=dist --platform=node --target=node24 ./src/main.ts",
    "eslint": "eslint --max-warnings 0 .",
    "format": "prettier --write '**/*.{json,js,jsx,ts,tsx,css}' --loglevel error",
    "lint": "npm run eslint && npm run types-check",
    "types-check": "tsc --noemit"
  },
  "engineStrict": true,
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "dependencies": {
    "@actions/core": "^2.0.1",
    "@actions/github": "^6.0.0",
    "@actions/io": "^1.1.3",
    "@actions/tool-cache": "^2.0.1",
    "axios": "^1.16.1",
    "https-proxy-agent": "^7.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^7.0.1",
    "esbuild": "^0.25.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  }
}
